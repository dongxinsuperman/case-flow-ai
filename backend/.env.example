CASE_FLOW_ENV=local
CASE_FLOW_API_HOST=127.0.0.1
CASE_FLOW_API_PORT=8800
CASE_FLOW_DATABASE_URL=postgresql+asyncpg://case_flow:case_flow@127.0.0.1:55432/case_flow
CASE_FLOW_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional LLM provider. Keep empty for local non-LLM flows.
CASE_FLOW_LLM_PROVIDER=ark
CASE_FLOW_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
CASE_FLOW_LLM_API_KEY=
CASE_FLOW_LLM_MODEL=doubao-seed-2-0-pro-260215
CASE_FLOW_LLM_MAX_TOKENS=16000

# OS Agent global feature switch.
CASE_FLOW_OS_AGENT_ENABLED=true

# Case matching (collision review) tuning.
CASE_FLOW_CASE_MATCH_MODEL_TOP_N=3
CASE_FLOW_CASE_MATCH_PRIMARY_THRESHOLD=80

# AI Phone 执行器地址：推送 submission 与查询在线设备都打到这里。
# 使用远程部署时改成对应 AI Phone 的地址（host:port）。
CASE_FLOW_AIPHONE_BASE_URL=http://127.0.0.1:8000
# AI Web 执行器地址：推送 submission 与查询浏览器槽都打到这里。
CASE_FLOW_AIWEB_BASE_URL=http://127.0.0.1:8009
# 回调与报告地址前缀：AI Phone/AI Web 回调、AI API 报告链接会使用它。
CASE_FLOW_PUBLIC_BASE_URL=http://127.0.0.1:8800
# AI Web 回调地址前缀：必须是 AI Web 服务能访问到的 case-flow 地址。
CASE_FLOW_AIWEB_CALLBACK_BASE_URL=http://127.0.0.1:8800

# AI API 内置接口执行器配置：自然语言 API case 会先被模型编排成 HTTP 请求，再由这里的开关控制执行范围。
# 可访问 host 白名单：空=不限制 host；填写后只允许这些域名/IP，例如 api.test.local,127.0.0.1。
CASE_FLOW_AIAPI_ALLOWED_HOSTS=
# 可访问 base_url 白名单：空=不限制服务前缀；填写后只允许这些基础地址，例如 http://127.0.0.1:5180/api。
CASE_FLOW_AIAPI_ALLOWED_BASE_URLS=
# 默认 base_url：当模型只生成 /path 而没有完整域名时，用它拼成完整 URL；空=必须由 case/functionMap 提供完整地址。
CASE_FLOW_AIAPI_DEFAULT_BASE_URL=
# 默认请求头：JSON 对象字符串，每个请求都会带上；适合统一 token、租户 ID、环境标识，报告会完整展示。
CASE_FLOW_AIAPI_DEFAULT_HEADERS=
# 允许的 HTTP 方法：只执行这里列出的方法；如果要禁止删除，就从这里去掉 DELETE。
CASE_FLOW_AIAPI_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE
# 是否允许本机/私网/内网地址：true=允许 localhost、127.0.0.1、10.x、172.16-31.x、192.168.x；false=拦截这些地址。
CASE_FLOW_AIAPI_ALLOW_PRIVATE_NETWORKS=true
# 单个接口最大超时时间，单位秒；防止接口长时间无响应拖住执行任务。
CASE_FLOW_AIAPI_MAX_TIMEOUT_SECONDS=20
# 响应体读取上限，单位字节；0=完整保留响应，不截断，报告里能看到完整返回。
CASE_FLOW_AIAPI_MAX_RESPONSE_BYTES=0
# 是否跟随 HTTP 重定向：false=不跟随 301/302；true=跟随跳转后继续请求。
CASE_FLOW_AIAPI_FOLLOW_REDIRECTS=false

# 飞书项目（Meego）来源：仅插件鉴权凭证（密钥）。拉哪些空间/时间/角色映射在
# backend/config/feishu_project.json。详见 docs/飞书项目接入.md。凭证绝不要提交到 Git。
CASE_FLOW_FEISHU_PROJECT_SITE_DOMAIN=https://project.feishu.cn
CASE_FLOW_FEISHU_PROJECT_PLUGIN_ID=
CASE_FLOW_FEISHU_PROJECT_PLUGIN_SECRET=
CASE_FLOW_FEISHU_PROJECT_USER_KEY=
# 飞书项目 MCP 第二通道：只用于 bug 描述里的富文本图片渲染，不替代 OpenAPI 建单。
# MCP_TOKEN 是用户身份令牌，必须在飞书项目 MCP 配置页开启“查看数据”和“创建/修改数据”。
CASE_FLOW_FEISHU_PROJECT_MCP_URL=https://project.feishu.cn/mcp_server/v1
CASE_FLOW_FEISHU_PROJECT_MCP_TOKEN=
